{
  "name": "healthvault",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "node -e \"require('fs').copyFileSync('.env.local.docker', '.env.local')\" && next dev",
    "dev:prod": "node -e \"const fs=require('fs');fs.copyFileSync('.env.local.prod','.env.local');console.log('Switched to PRODUCTION Supabase');\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write --ignore-unknown 'src/**/*.{ts,tsx,js,jsx,json,css}'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:reset": "npx supabase db reset",
    "db:seed": "node --env-file=.env.local scripts/seed-users.mjs",
    "db:studio": "start http://127.0.0.1:56323",
    "prepare": "husky"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google/generative-ai": "^0.24.1",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.1.1",
    "@sentry/nextjs": "^10.59.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.4.11",
    "html5-qrcode": "^2.3.8",
    "nanoid": "^5.1.15",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,json,md,css}": [
      "prettier --write --ignore-unknown --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6",
    "whatwg-fetch": "^3.6.20"
  }
}
